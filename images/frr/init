#!/usr/bin/env bash
set -euo pipefail

SOCK=/var/run/frr/reload.sock
FRR_CONF=/etc/frr/frr.conf
FRR_WATCH=/usr/lib/frr/watchfrr
STOP=0
SOCAT_PID=

cleanup() {
  STOP=1
  if [[ -S "$SOCK" || -e "$SOCK" ]]; then
    rm -f "$SOCK"
  fi
  if [[ -n "${SOCAT_PID}" ]]; then
    kill "$SOCAT_PID" 2>/dev/null || true
  fi
  "$FRR_START" stop || true
  exit 0
}

trap cleanup TERM INT

rm -f "$SOCK"
$FRR_WATCH \
    -i 5 \
    -t 20 \
    --min-restart-interval 5 \
    --max-restart-interval 20 \
    zebra staticd bgpd &

python3 probe &

while [[ "$STOP" -eq 0 ]]; do
  socat -u "UNIX-LISTEN:$SOCK,fork,unlink-close" EXEC:/handle-command &
  SOCAT_PID=$!
  wait "$SOCAT_PID" || true
done
